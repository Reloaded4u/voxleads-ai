{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "name": { "type": "string", "description": "Full name of the lead" },
        "phone": { "type": "string", "description": "Phone number" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "location": { "type": "string", "description": "Geographic location" },
        "notes": { "type": "string", "description": "Additional notes" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Interested", "Not Interested", "Follow-up", "Booked"], "description": "Current status of the lead" },
        "source": { "type": "string", "description": "Where the lead came from" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for categorization" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "phone", "status"]
    },
    "CallRecord": {
      "title": "CallRecord",
      "description": "A record of an AI voice call.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "leadId": { "type": "string", "description": "ID of the lead called" },
        "timestamp": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Call duration in seconds" },
        "status": { "type": "string", "enum": ["queued", "initiated", "ringing", "in-progress", "completed", "missed", "failed", "no-answer", "busy"] },
        "provider": { "type": "string", "enum": ["twilio", "mock"] },
        "callSid": { "type": "string" },
        "cost": { "type": "number" },
        "summary": { "type": "string", "description": "AI generated summary" },
        "transcript": { "type": "string", "description": "Full call transcript" },
        "outcome": { "type": "string", "description": "Lead status after call" },
        "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative"] },
        "keyPoints": { "type": "array", "items": { "type": "string" } },
        "objectionsRaised": { "type": "array", "items": { "type": "string" } },
        "nextAction": { "type": "string" },
        "recordingUrl": { "type": "string" },
        "recordingSid": { "type": "string" },
        "recordingStatus": { "type": "string", "enum": ["requested", "processing", "completed", "failed"] },
        "controlState": { "type": "string", "enum": ["ai_active", "agent_join_requested", "agent_joined", "handoff_completed", "call_ended"] },
        "assignedAgentId": { "type": "string" }
      },
      "required": ["ownerId", "leadId", "timestamp", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled meeting or site visit.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "leadId": { "type": "string" },
        "leadName": { "type": "string" },
        "leadPhone": { "type": "string" },
        "type": { "type": "string", "enum": ["Site Visit", "Follow-up", "Consultation", "Contract Signing"] },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Cancelled", "Rescheduled"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "smsAlertSent": { "type": "boolean" }
      },
      "required": ["ownerId", "leadId", "type", "status", "scheduledAt", "duration", "createdBy"]
    },
    "SMSLog": {
      "title": "SMSLog",
      "description": "A log of an SMS message sent via the system.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "recipient": { "type": "string" },
        "body": { "type": "string" },
        "eventType": { "type": "string", "enum": ["appointment_scheduled", "daily_summary", "manual"] },
        "status": { "type": "string", "enum": ["queued", "sent", "failed", "delivered"] },
        "providerMessageId": { "type": "string" },
        "error": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "recipient", "body", "eventType", "status", "createdAt"]
    },
    "CallEvent": {
      "title": "CallEvent",
      "description": "An event in the timeline of a call.",
      "type": "object",
      "properties": {
        "callId": { "type": "string" },
        "ownerId": { "type": "string" },
        "type": { "type": "string", "enum": ["ai_start", "agent_join_requested", "agent_joined", "handoff_completed", "call_ended", "note"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "note": { "type": "string" }
      },
      "required": ["callId", "ownerId", "type", "timestamp"]
    },
    "KnowledgeBaseSection": {
      "title": "KnowledgeBaseSection",
      "description": "A section of the knowledge base for a user.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "data": { "type": "object", "description": "Section specific data" }
      },
      "required": ["ownerId", "updatedAt"]
    },
    "QueueItem": {
      "title": "QueueItem",
      "description": "An item in the automated calling queue.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "leadId": { "type": "string" },
        "phone": { "type": "string" },
        "normalizedPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "processing", "completed", "failed", "no_answer", "busy", "cancelled"] },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "attempts": { "type": "number" },
        "maxAttempts": { "type": "number" },
        "lastAttemptAt": { "type": "string", "format": "date-time" },
        "nextRetryAt": { "type": "string", "format": "date-time" },
        "retryReason": { "type": "string" },
        "lastError": { "type": "string" },
        "activeCallId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "leadId", "phone", "normalizedPhone", "status", "scheduledTime", "attempts", "maxAttempts", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent"] },
        "settings": {
          "type": "object",
          "properties": {
            "voiceId": { "type": "string" },
            "agentPersonality": { "type": "string" },
            "notificationsEnabled": { "type": "boolean" },
            "callingStartTime": { "type": "string", "description": "HH:mm format" },
            "callingEndTime": { "type": "string", "description": "HH:mm format" },
            "timezone": { "type": "string", "description": "IANA timezone string" },
            "autoCallingEnabled": { "type": "boolean" },
            "maxCallsPerMinute": { "type": "number" },
            "maxRetryAttempts": { "type": "number" },
            "retryDelayMinutes": { "type": "number" },
            "autoQueueOnImport": { "type": "boolean" }
          }
        },
        "communication": {
          "type": "object",
          "properties": {
            "smsAlertsEnabled": { "type": "boolean" },
            "meetingSmsRecipients": { "type": "array", "items": { "type": "string" } },
            "sendLeadConfirmationSms": { "type": "boolean" },
            "dailySummaryEnabled": { "type": "boolean" },
            "dailySummaryTime": { "type": "string" },
            "dailySummaryTimezone": { "type": "string" },
            "dailySummaryRecipient": { "type": "string" },
            "recordingEnabled": { "type": "boolean" },
            "agentTakeoverEnabled": { "type": "boolean" },
            "liveCallingEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email", "displayName", "role"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads"
    },
    "/calls/{callId}": {
      "schema": "CallRecord",
      "description": "Collection of call records"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of appointments"
    },
    "/users/{userId}/knowledgeBase/{sectionId}": {
      "schema": "KnowledgeBaseSection",
      "description": "Sub-collection for user knowledge base sections"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings"
    },
    "/callQueue/{itemId}": {
      "schema": "QueueItem",
      "description": "Collection of items in the calling queue"
    }
  }
}
