rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Fields:
    //   - ownerId: string (required, immutable) - UID of the owner
    //   - name: string (required) - Full name
    //   - phone: string (required) - Phone number
    //   - status: string (required, enum) - Lead status
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: calls
    // Fields:
    //   - ownerId: string (required, immutable) - UID of the owner
    //   - leadId: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: appointments
    // Fields:
    //   - ownerId: string (required, immutable) - UID of the owner
    //   - leadId: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users
    // Fields:
    //   - role: string (required) - 'admin' or 'agent'
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "tinkuitarsii@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
    }

    function createdAtUnchanged() {
      return !('createdAt' in request.resource.data) || 
             request.resource.data.createdAt == resource.data.createdAt;
    }

    function ownerIdUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function validString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    function isValidLead(data) {
      let validStatuses = ["New", "Contacted", "Interested", "Not Interested", "Follow-up", "Booked"];
      return validString(data.name, 100) &&
             validString(data.phone, 20) &&
             (!('email' in data) || validString(data.email, 100)) &&
             (!('location' in data) || validString(data.location, 200)) &&
             (!('notes' in data) || data.notes is string && data.notes.size() <= 2000) &&
             data.status in validStatuses &&
             data.ownerId is string &&
             data.createdAt is timestamp;
    }

    function isValidCall(data) {
      return data.leadId is string &&
             data.ownerId is string &&
             data.createdAt is timestamp &&
             (!('summary' in data) || data.summary is string && data.summary.size() <= 5000) &&
             (!('transcript' in data) || data.transcript is string && data.transcript.size() <= 50000);
    }

    function isValidQueueItem(data) {
      let validStatuses = ["pending", "scheduled", "processing", "completed", "failed", "no_answer", "busy", "cancelled"];
      return data.ownerId is string &&
             data.leadId is string &&
             data.phone is string &&
             data.normalizedPhone is string &&
             data.status in validStatuses &&
             data.scheduledTime is timestamp &&
             data.attempts is number &&
             data.maxAttempts is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidAppointment(data) {
      let validTypes = ["Site Visit", "Follow-up", "Consultation", "Contract Signing"];
      let validStatuses = ["Scheduled", "Completed", "Cancelled", "Rescheduled"];
      return data.leadId is string &&
             data.ownerId is string &&
             data.leadName is string &&
             data.type in validTypes &&
             data.status in validStatuses &&
             data.scheduledAt is timestamp &&
             data.duration is number && data.duration > 0 &&
             data.createdAt is timestamp &&
             data.createdBy is string &&
             (!('location' in data) || data.location is string && data.location.size() <= 500) &&
             (!('notes' in data) || data.notes is string && data.notes.size() <= 2000);
    }

    function isValidUser(data) {
      return data.role in ['admin', 'agent'] &&
             data.email is string &&
             data.displayName is string &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('settings' in data) || data.settings is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leads/{leadId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidLead(request.resource.data);
      allow update: if isDocOwner() && ownerIdUnchanged() && createdAtUnchanged() && isValidLead(request.resource.data);
      allow delete: if isAdmin();
    }

    match /calls/{callId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidCall(request.resource.data);
      allow update: if isDocOwner() && ownerIdUnchanged() && createdAtUnchanged() && isValidCall(request.resource.data);
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidAppointment(request.resource.data) && request.resource.data.scheduledAt > request.time;
      allow update: if isDocOwner() && ownerIdUnchanged() && createdAtUnchanged() && isValidAppointment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own profile but role must be 'agent' unless they are the bootstrap admin
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'agent' || isAdmin());
      // Users cannot change their own role
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || 
                    isAdmin();
      allow delete: if isAdmin();

      match /knowledgeBase/{sectionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /smsLogs/{logId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner();
      allow update: if (isDocOwner() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'providerMessageId', 'updatedAt', 'error'])) || 
                     isAdmin();
      allow delete: if isAdmin();
    }

    match /callEvents/{eventId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner();
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    match /callQueue/{queueId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isNewDocOwner() && isValidQueueItem(request.resource.data);
      allow update: if (isDocOwner() && ownerIdUnchanged() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'scheduledTime'])) || 
                     isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
